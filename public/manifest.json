{
  "manifest_version": 3,
  "name": "MSN - Money Sync to Notion",
  "version": "1.1",
  "description": "Extracts the balance amount from a page.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://api.notion.com/*"],
  "options_page": "src/options/index.html",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/attempt-3-minimal-arrow-grid-16.png",
      "32": "icons/attempt-3-minimal-arrow-grid-32.png",
      "48": "icons/attempt-3-minimal-arrow-grid-48.png",
      "128": "icons/attempt-3-minimal-arrow-grid-128.png"
    }
  }
}
